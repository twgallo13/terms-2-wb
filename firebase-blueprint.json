{
  "entities": {
    "Vendor": {
      "title": "Vendor",
      "description": "A company providing products or services.",
      "type": "object",
      "properties": {
        "legalName": { "type": "string", "description": "Legal name of the vendor." },
        "status": { "type": "string", "enum": ["active", "pending", "inactive"], "description": "Current status of the vendor." },
        "createdAt": { "type": "string", "format": "date-time", "description": "When the vendor was created." },
        "updatedAt": { "type": "string", "format": "date-time", "description": "When the vendor was last updated." }
      },
      "required": ["legalName", "status"]
    },
    "Brand": {
      "title": "Brand",
      "description": "A specific brand under a vendor.",
      "type": "object",
      "properties": {
        "vendorId": { "type": "string", "description": "ID of the parent vendor." },
        "brandName": { "type": "string", "description": "Name of the brand." },
        "status": { "type": "string", "enum": ["active", "inactive"], "description": "Current status of the brand." }
      },
      "required": ["vendorId", "brandName", "status"]
    },
    "Quote": {
      "title": "Quote",
      "description": "A commercial offer sent to a vendor.",
      "type": "object",
      "properties": {
        "quoteNumber": { "type": "string", "description": "Unique quote identifier." },
        "vendorId": { "type": "string", "description": "ID of the vendor." },
        "brandId": { "type": "string", "description": "ID of the brand." },
        "status": { "type": "string", "enum": ["draft", "sent", "accepted", "rejected", "expired"], "description": "Current status of the quote." },
        "versionNumber": { "type": "string", "description": "Current version of the quote." },
        "createdAt": { "type": "string", "format": "date-time", "description": "When the quote was created." }
      },
      "required": ["quoteNumber", "vendorId", "brandId", "status"]
    },
    "Agreement": {
      "title": "Agreement",
      "description": "A finalized legal agreement.",
      "type": "object",
      "properties": {
        "agreementNumber": { "type": "string", "description": "Unique agreement identifier." },
        "vendorId": { "type": "string", "description": "ID of the vendor." },
        "brandId": { "type": "string", "description": "ID of the brand." },
        "status": { "type": "string", "enum": ["draft", "sent", "signed", "void"], "description": "Current status of the agreement." },
        "createdAt": { "type": "string", "format": "date-time", "description": "When the agreement was created." }
      },
      "required": ["agreementNumber", "vendorId", "brandId", "status"]
    },
    "AccessLink": {
      "title": "Access Link",
      "description": "A secure link for vendor review.",
      "type": "object",
      "properties": {
        "tokenHash": { "type": "string", "description": "SHA-256 hash of the access token." },
        "entityId": { "type": "string", "description": "ID of the quote or agreement." },
        "entityType": { "type": "string", "enum": ["quote", "agreement"], "description": "Type of the entity." },
        "recipientEmail": { "type": "string", "format": "email", "description": "Email of the recipient." },
        "status": { "type": "string", "enum": ["active", "superseded", "expired"], "description": "Current status of the link." },
        "expiresAt": { "type": "string", "format": "date-time", "description": "When the link expires." },
        "currentUseCount": { "type": "integer", "description": "Number of times the link has been used." }
      },
      "required": ["tokenHash", "entityId", "entityType", "recipientEmail", "status"]
    },
    "UserProfile": {
      "title": "User Profile",
      "description": "A profile for an internal or vendor user.",
      "type": "object",
      "properties": {
        "email": { "type": "string", "format": "email", "description": "Email of the user." },
        "displayName": { "type": "string", "description": "Display name of the user." },
        "isInternal": { "type": "boolean", "description": "Whether the user is an internal Shiekh Shoes employee." },
        "role": { "type": "string", "description": "Role of the user (e.g., administrator, vendor_contact)." },
        "vendorId": { "type": "string", "description": "ID of the vendor (for vendor users)." }
      },
      "required": ["email", "isInternal"]
    }
  },
  "firestore": {
    "/vendors/{vendorId}": { "schema": "Vendor", "description": "Vendor records." },
    "/brands/{brandId}": { "schema": "Brand", "description": "Brand records." },
    "/quotes/{quoteId}": { "schema": "Quote", "description": "Quote records." },
    "/agreements/{agreementId}": { "schema": "Agreement", "description": "Agreement records." },
    "/accessLinks/{linkId}": { "schema": "AccessLink", "description": "Secure access links." },
    "/userProfiles/{userId}": { "schema": "UserProfile", "description": "User profiles." },
    "/activityLogs/{logId}": { "schema": { "type": "object" }, "description": "Audit logs." }
  }
}
