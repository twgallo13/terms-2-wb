rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: vendors
    // Fields: legalName (string), status (string), createdAt (timestamp), updatedAt (timestamp)
    //
    // Collection: brands
    // Fields: vendorId (string), brandName (string), status (string)
    //
    // Collection: quotes
    // Fields: quoteNumber (string), vendorId (string), brandId (string), status (string), versionNumber (string), createdAt (timestamp)
    //
    // Collection: agreements
    // Fields: agreementNumber (string), vendorId (string), brandId (string), status (string), createdAt (timestamp)
    //
    // Collection: accessLinks
    // Fields: tokenHash (string), entityId (string), entityType (string), recipientEmail (string), status (string), expiresAt (timestamp), currentUseCount (int)
    //
    // Collection: userProfiles
    // Fields: email (string), displayName (string), isInternal (bool), role (string), vendorId (string)
    //
    // Collection: activityLogs
    // Fields: action (string), timestamp (timestamp), details (map)
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================

    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() &&
        (get(/databases/$(database)/documents/userProfiles/$(request.auth.uid)).data.role == 'administrator' ||
          (request.auth.token.email == "theo@shiekhshoes.org" && request.auth.token.email_verified == true));
    }

    function isInternal() {
      return isAuthenticated() && get(/databases/$(database)/documents/userProfiles/$(request.auth.uid)).data.isInternal == true;
    }

    function isVendorUser(vendorId) {
      return isAuthenticated() && get(/databases/$(database)/documents/userProfiles/$(request.auth.uid)).data.vendorId == vendorId;
    }

    function hasRequiredFields(fields) {
      return request.resource.data.keys().hasAll(fields);
    }

    function hasOnlyAllowedFields(fields) {
      return request.resource.data.keys().hasOnly(fields);
    }

    function uidNotModified() {
      return !('uid' in request.resource.data) || request.resource.data.uid == resource.data.uid;
    }

    // ===============================================================
    // Domain Validators
    // ===============================================================

    function isValidVendor(data) {
      return data.legalName is string && data.legalName.size() > 0 && data.legalName.size() < 200 &&
             data.status in ['active', 'pending', 'inactive'];
    }

    function isValidBrand(data) {
      return data.vendorId is string && data.brandName is string && data.brandName.size() > 0 &&
             data.status in ['active', 'inactive'];
    }

    function isValidQuote(data) {
      return data.quoteNumber is string && data.vendorId is string && data.brandId is string &&
             data.status in ['draft', 'sent', 'accepted', 'rejected', 'expired'];
    }

    function isValidAgreement(data) {
      return data.agreementNumber is string && data.vendorId is string && data.brandId is string &&
             data.status in ['draft', 'sent', 'signed', 'void'];
    }

    function isValidAccessLink(data) {
      return data.tokenHash is string && data.entityId is string && data.entityType in ['quote', 'agreement'] &&
             data.recipientEmail is string && data.status in ['active', 'superseded', 'expired'];
    }

    function isValidUserProfile(data) {
      return data.email is string && data.isInternal is bool &&
             (!('displayName' in data) || (data.displayName is string && data.displayName.size() < 100)) &&
             (!('role' in data) || (data.role is string && data.role.size() < 50)) &&
             (!('vendorId' in data) || (data.vendorId is string));
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /vendors/{vendorId} {
      allow read: if isInternal() || isVendorUser(vendorId);
      allow create, update: if isInternal() && isValidVendor(request.resource.data);
      allow delete: if isAdmin();
    }

    match /brands/{brandId} {
      allow read: if isInternal() || isVendorUser(resource.data.vendorId);
      allow create, update: if isInternal() && isValidBrand(request.resource.data);
      allow delete: if isAdmin();
    }

    match /quotes/{quoteId} {
      allow read: if isInternal() || isVendorUser(resource.data.vendorId);
      allow create, update: if isInternal() && isValidQuote(request.resource.data);
      allow delete: if isAdmin();
    }

    match /agreements/{agreementId} {
      allow read: if isInternal() || isVendorUser(resource.data.vendorId);
      allow create, update: if isInternal() && isValidAgreement(request.resource.data);
      allow delete: if isAdmin();
    }

    match /accessLinks/{linkId} {
      // Access links are primarily read by the backend (admin SDK) or via specific token validation
      // But we allow internal users to manage them
      allow read: if isInternal();
      allow create, update: if isInternal() && isValidAccessLink(request.resource.data);
      allow delete: if isAdmin();
    }

    match /userProfiles/{userId} {
      allow read: if isOwner(userId) || isInternal();
      allow create: if (isOwner(userId) && request.resource.data.isInternal == false) || isAdmin();
      allow update: if (isOwner(userId) && request.resource.data.isInternal == resource.data.isInternal && request.resource.data.role == resource.data.role) || isAdmin();
      allow delete: if isAdmin();
    }

    match /activityLogs/{logId} {
      allow read: if isInternal();
      allow create: if isAuthenticated(); // Allow logging from various actions
      allow update, delete: if isAdmin();
    }

    // Default deny
    match /{path=**} {
      allow read, write: if false;
    }
  }
}
